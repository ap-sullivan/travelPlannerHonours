{
  "expo": {
    "name": "travelPlanner",
    "slug": "travelPlanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/logo.png",
     "splash": {
      "image": "./assets/logo/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#e7e7e7"
    },
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.travelPlanner",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.829140211747-4dme59dodsk66bm5kf7edjk0jf5b19f6"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.829140211747-4dme59dodsk66bm5kf7edjk0jf5b19f6"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/logo.png",
        "backgroundColor": "#e7e7e7"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.travelPlanner",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-font",
      "@rnmapbox/maps",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "f21e2f5f-1b54-4420-98b9-aa8a70eb994e"
      }
    },
    "owner": "thewebdeveloperglasgow"
  }
}
